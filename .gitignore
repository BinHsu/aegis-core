# =============================================================================
# Aegis Core .gitignore
#
# This file enforces the "strict directory confinement" property of
# CLAUDE.md Rule 6: every dependency, cache, virtualenv, node_modules, model
# weights blob, and build artifact stays inside the repository tree and never
# leaks into the user's global system directories. It also prevents OS /
# editor artifacts from polluting commits.
# =============================================================================

# --- macOS ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# --- Windows -------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# --- Linux ---------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- Editors / IDEs ------------------------------------------------------
.vscode/
!.vscode/settings.shared.json
.idea/
*.iml
*.ipr
*.iws
.vs/
*.user
*.suo
*.swp
*.swo
*.swn
Session.vim
.netrwhist
tags
.clangd/

# --- Bazel (CLAUDE.md Rule 6) --------------------------------------------
# All Bazel caches MUST stay inside the repo per .bazelrc
# (--output_user_root=./.bazel_cache).
.bazel_cache/
.bazelisk/
.bufsk/
bazel-*
MODULE.bazel.lock
!MODULE.bazel
.bazelrc.user

# --- Python (CLAUDE.md Rule 6) -------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.egg-info/

# --- Node.js (CLAUDE.md Rule 6) ------------------------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarnrc.yml.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Go ------------------------------------------------------------------
# Go modules live inside gateway_go/; we do NOT ignore go.sum.
vendor/
*.test
*.out

# --- Rust (Phase 4+ Tauri shell) ----------------------------------------
# Keep Cargo.lock tracked per Rust best practice for applications.
target/
**/*.rs.bk
*.pdb

# --- C / C++ build outputs ----------------------------------------------
*.o
*.obj
*.ko
*.elf
*.exe
*.dll
*.dylib
*.so
*.so.*
*.a
*.lib
*.la
*.lo
*.slo
*.dSYM/
*.gch
*.pch
*.idb
*.ilk
*.map

# --- AI model artifacts (ARCH §10.1) -------------------------------------
# Manifests (manifest.json) ARE tracked and contain SHA256 + provenance.
# Binary model files are NOT tracked and are downloaded on demand,
# verified against the manifest, then mmapped by the engine.
/models/*.gguf
/models/*.bin
/models/*.onnx
/models/*.safetensors
/models/*.pt
/models/*.pth
/models/*.ckpt
/models/cache/
/models/downloads/

# --- Secrets and environment files ---------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.keystore
*.p12
*.jks
credentials.json
service-account*.json

# --- Generated code ------------------------------------------------------
# C++ bindings (.pb.cc/.h) and TS bindings live ONLY in bazel-bin/ and
# the frontend's pnpm output — not committed.
**/generated/
**/_gen/
*.pb.cc
*.pb.h
*.pb.ts
*_pb.js
*_pb.d.ts
*_grpc.pb.cc
*_grpc.pb.h

# Go .pb.go files are intentionally CHECKED IN per ADR-0013 (proto
# codegen distribution strategy) so gopls / IDE / `go build` work
# without launching Bazel. Bazel remains the authoritative producer;
# CI's drift check (./tools/scripts/proto_gen.sh + git diff
# --exit-code) keeps the checked-in tree in sync with .proto sources.
# Therefore we do NOT exclude *.pb.go / *_grpc.pb.go here.

# --- Logs and debug ------------------------------------------------------
*.log
*.log.*
logs/
crash.log
npm-debug.log
yarn-debug.log

# --- Coverage and test outputs -------------------------------------------
coverage/
.nyc_output/
*.lcov

# --- Misc ---------------------------------------------------------------
.DS_Store?
._.DS_Store
.Spotlight-V100
.Trashes

# --- Author-personal files (NOT for repo consumers) ---------------------
# Private interview-prep reference maintained by the author. Contains
# portfolio positioning, likely interviewer questions, and suggested
# answer frames that map to this repo's code. A downstream consumer
# cloning the repo for its actual utility should NOT have to carry the
# author's personal career material, so it stays out of version control.
/interview-prep.md
