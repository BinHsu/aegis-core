# Repo-local pnpm configuration. Honored by the Bazel-managed pnpm
# invoked via tools/scripts/frontend.sh (and by any ad-hoc
# `bazel run -- @pnpm//:pnpm` invocations).
#
# `store-dir` pins pnpm's content-addressable store inside this repo
# rather than at the user home (~/Library/pnpm/store) or — as
# observed without this file — the parent volume root. CLAUDE.md
# Rule 6 ("strict directory confinement") requires every dependency
# to live inside the repo tree.
#
# `virtual-store-dir` likewise pins the virtual-store location
# (normally node_modules/.pnpm) to an in-repo path for symmetry.

store-dir=.pnpm-store
