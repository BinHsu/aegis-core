#
#   bazel_dep(name = "grpc",           version = "1.66.0", repo_name = "com_github_grpc_grpc")  # ADR-0009
#   bazel_dep(name = "rules_go",       version = "0.50.1")                                      # Phase 2
#   bazel_dep(name = "gazelle",        version = "0.39.1")                                      # Phase 2
#   bazel_dep(name = "rules_cc",       version = "0.0.17")                                      # Phase 1 engine
#   bazel_dep(name = "rules_foreign_cc", version = "0.12.0")                                    # ADR-0009 whisper.cpp
#   bazel_dep(name = "rules_nodejs",   version = "6.3.2")                                       # Phase 3 frontend
#   bazel_dep(name = "rules_oci",      version = "2.0.1")                                       # Phase 4 packaging
#   bazel_dep(name = "rules_rust",     version = "0.54.0")                                      # Phase 4 Tauri
#
# They are commented here, not added, because:
#   (a) Cold-building grpc-cpp takes 5-15 min (ADR-0009) — not worth
#       it until we're actually building C++ targets.
#   (b) Each dep adds build graph surface and possible version conflicts.
#   (c) Session 1 scope is just proto_library validation.
