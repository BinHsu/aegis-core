"""Aegis Core Bazel module (bzlmod).

Per ADR-0008 (Monorepo Folder Structure) and ADR-0009 (C++ Build and
Toolchain). This file is the source of truth for every external
dependency; supports CLAUDE.md Rule 6 (strict directory confinement)
since all deps download into ./.bazel_cache/ via --output_user_root.

Version bumps MUST be accompanied by:
  1. A review of the dependency's license (MIT/Apache-2.0/BSD OK,
     GPL/AGPL blocked per ARCHITECTURE.md §10.1).
  2. CI green on the corresponding PR.
  3. If the dep is a model or runtime, a WER regression run per
     ADR-0011.
"""

module(
    name = "aegis_core",
    version = "0.1.0",
    compatibility_level = 1,
)

# -----------------------------------------------------------------------------
# Proto & Protobuf — the backbone of proto/aegis/v1/.
# -----------------------------------------------------------------------------
bazel_dep(name = "rules_proto", version = "7.0.2")
bazel_dep(name = "protobuf", version = "28.2", repo_name = "com_google_protobuf")

# -----------------------------------------------------------------------------
